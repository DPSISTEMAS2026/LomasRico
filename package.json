{
    "name": "lo-mas-rico-v2",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev -w apps/web -- --port 3000\" \"npm run dev -w apps/api\" \"npm run dev -w apps/panels -- --port 3002\"",
        "dev:api": "npm run dev -w apps/api",
        "dev:web": "npm run dev -w apps/web -- --port 3000",
        "dev:panels": "npm run dev -w apps/panels -- --port 3002",
        "build": "npm run build --workspaces --if-present",
        "lint": "npm run lint --workspaces --if-present",
        "db:up": "docker-compose -f infra/local/docker-compose.yml up -d postgres",
        "db:stop": "docker-compose -f infra/local/docker-compose.yml stop",
        "studio": "npx prisma studio --schema=packages/database/prisma/schema.prisma"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "concurrently": "^8.2.2",
        "eslint": "^8.56.0",
        "prettier": "^3.2.4",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "ajv": "^8.18.0",
        "bcryptjs": "^3.0.3",
        "next": "15.1.0",
        "xlsx": "^0.18.5"
    }
}
