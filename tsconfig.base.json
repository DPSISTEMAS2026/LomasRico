{
    "compilerOptions": {
        "baseUrl": ".",
        "target": "ES2021",
        "module": "CommonJS",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@lomasrico/*": [
                "packages/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}